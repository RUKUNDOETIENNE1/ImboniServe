# ============================================================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env.production and fill in all values
# NEVER commit .env.production to version control!
# ============================================================================

# ============================================================================
# 🔴 CRITICAL - MUST BE SET
# ============================================================================

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# NextAuth Configuration
NEXTAUTH_SECRET="GENERATE_NEW_32_CHAR_SECRET_HERE"  # Generate with: openssl rand -hex 32
NEXTAUTH_URL="https://your-production-domain.com"
ALLOW_LEGACY_CREDENTIALS="false"  # Do NOT enable in production

# ============================================================================
# 🟡 HIGH PRIORITY - REQUIRED FOR CORE FEATURES
# ============================================================================

# InTouch Mobile Money (Primary Payment Gateway)
INTOUCH_API_URL="https://www.intouchpay.co.rw/api"
INTOUCH_USERNAME="your-intouch-username"
INTOUCH_ACCOUNT_NO="your-account-number"
INTOUCH_PASSWORD="your-partner-password"
# InTouch webhook auth (Basic Auth) — REQUIRED
INTOUCH_WEBHOOK_USERNAME="your-webhook-username"
INTOUCH_WEBHOOK_PASSWORD="your-webhook-password"

# IremboPay (Card Payments) — Provider-based integration
# If you enable card payments via the provider layer
IREMBOPAY_API_URL="https://api.irembo.com"  # or sandbox URL
IREMBOPAY_MERCHANT_ID="your-merchant-id"
IREMBOPAY_API_KEY="your-api-key"
IREMBOPAY_API_SECRET="your-api-secret"
IREMBOPAY_CALLBACK_URL="https://your-production-domain.com/api/webhooks/irembopay"
IREMBOPAY_RETURN_URL="https://your-production-domain.com/billing/payment-result"

# Twilio (WhatsApp & SMS)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_WHATSAPP_NUMBER="whatsapp:+1234567890"
TWILIO_PHONE_NUMBER="+1234567890"

# Supabase Storage (File Uploads)
STORAGE_PROVIDER="supabase"
SUPABASE_STORAGE_BUCKET="media-uploads"
SUPABASE_STORAGE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_STORAGE_KEY="your-service-role-key"

# ============================================================================
# 🟢 MEDIUM PRIORITY - RECOMMENDED
# ============================================================================

# Sentry (Error Monitoring)
SENTRY_DSN="https://[KEY]@[ORG].ingest.sentry.io/[PROJECT]"
NEXT_PUBLIC_SENTRY_DSN="https://[KEY]@[ORG].ingest.sentry.io/[PROJECT]"
SENTRY_ENVIRONMENT="production"
SENTRY_TRACES_SAMPLE_RATE="0.1"

# OpenAI (AI Features)
OPENAI_API_KEY="sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OPENAI_MODEL_PRIMARY="gpt-4o-mini"
OPENAI_MODEL_FALLBACK="gpt-4-turbo"
OPENAI_COST_INPUT_PER_1K_USD="0.00015"
OPENAI_COST_OUTPUT_PER_1K_USD="0.00060"

# Document Information Extraction (DIE) - Azure Document Intelligence (optional)
# Primary extraction provider when configured; falls back to OpenAI Vision automatically.
# Leave commented out to use OpenAI Vision only.
# AZURE_DI_ENDPOINT="https://<region>.cognitiveservices.azure.com/"
# AZURE_DI_KEY="your-azure-document-intelligence-key-1"
# DIE tuning
DIE_MAX_DOC_MB="10"
DIE_PROVIDER_TIMEOUT_MS="30000"

# Cron Jobs
CRON_SECRET="GENERATE_NEW_32_CHAR_SECRET_HERE"  # Generate with: openssl rand -hex 32
CRON_WORKER="false"  # Use Vercel Cron, not worker process

# Pusher (Real-time Updates)
PUSHER_APP_ID="your-app-id"
PUSHER_KEY="your-key"
PUSHER_SECRET="your-secret"
PUSHER_CLUSTER="eu"  # or us2, ap1, etc.
NEXT_PUBLIC_PUSHER_KEY="your-key"
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# ============================================================================
# 🔵 LOW PRIORITY - OPTIONAL
# ============================================================================

# IremboPay (Fallback Payment Gateway)
IREMBOPAY_PUBLIC_KEY="your-public-key"
IREMBOPAY_SECRET_KEY="your-secret-key"
IREMBOPAY_PAYMENT_ACCOUNT="LOYALTECH-RWF"
IREMBOPAY_PAYMENT_ITEM_CODE="your-item-code"
IREMBOPAY_API_BASE="https://api.irembopay.com"
IREMBOPAY_API_VERSION="2"
IREMBOPAY_WEBHOOK_TOLERANCE_SECONDS="300"
PAYMENTS_PROVIDER="intouch"

# Redis (Job Queue - Optional)
REDIS_URL="rediss://default:[PASSWORD]@[HOST]:6379"

# Crisp Chat (Customer Support - Optional)
NEXT_PUBLIC_CRISP_WEBSITE_ID="your-website-id"

# ============================================================================
# APP CONFIGURATION
# ============================================================================

# App Settings
APP_URL="https://your-production-domain.com"
SUPPORT_PHONE="+250788917126"
SUPPORT_WHATSAPP="+250788917126"
SUPPORT_EMAIL="support@imboniserve.com"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_SECURE="true"
SMTP_FROM="Imboni Serve <your-email@gmail.com>"
ALERT_EMAIL_TO="ops@imboniserve.com"  # Where to send alert emails
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/XXX/YYY/ZZZ"  # Slack alerts webhook

# Media Upload Limits
MAX_VIDEO_DURATION_SEC="30"
MAX_VIDEO_SIZE_MB="50"
MAX_IMAGE_SIZE_MB="10"

# Smart QR Security
IMBONI_QR_SECRET="GENERATE_NEW_32_CHAR_SECRET_HERE"

# Trial & Business Approval
TRIAL_HASH_SECRET="GENERATE_NEW_32_CHAR_SECRET_HERE"
AUTO_APPROVE_THRESHOLD="30"
TRIAL_IP_RANGE_LIMIT="5"
CAPTCHA_ENABLED="false"
CAPTCHA_TEST_MODE="false"
DISPOSABLE_EMAIL_DOMAINS="tempmail.com,guerrillamail.com,10minutemail.com"

# AI Features
AI_SRO_ENABLED="true"
SRO_DAYS_WINDOW="14"
SRO_SAFETY_STOCK_DAYS="1"
DEFAULT_LEAD_TIME_DAYS="2"
AI_CPA_ENABLED="true"
CPA_THRESHOLD_PERCENT="10"

# AI Credits
AI_CREDITS_ENABLED="true"
AI_CREDITS_COST_BUSINESS_SCANNER="5"
AI_CREDITS_COST_SITE_BUILDER_AI="3"
AI_CREDITS_COST_MENU_SUGGESTIONS="2"

# Add-on Pricing (in RWF cents)
SITE_BUILDER_PRO_MONTHLY_PRICE="1200000"
DISCOVERY_FEATURED_MONTHLY_PRICE="800000"
DISCOVERY_PREMIUM_MONTHLY_PRICE="1500000"
AI_CREDITS_PACK_SMALL="1000000"
AI_CREDITS_PACK_MEDIUM="2500000"
AI_CREDITS_PACK_LARGE="4500000"

# Feature Flags
FEATURE_FLAG_AUTO_CHECK_ENABLED="true"

# Service Worker (PWA)
NEXT_PUBLIC_ENABLE_SW_DEV="false"

# Logging
LOG_LEVEL="info"

# Support Auto-conversion
SUPPORT_PUBLIC_BUSINESS_ID=""
SUPPORT_ASSIGN_USER_ID=""

# ============================================================================
# SECURITY CHECKLIST
# ============================================================================
# [ ] All secrets are unique and not from .env.example
# [ ] NEXTAUTH_SECRET is 32+ characters
# [ ] NEXTAUTH_URL matches your production domain
# [ ] Database URLs are from Supabase production project
# [ ] Payment gateway credentials are production (not sandbox)
# [ ] Twilio credentials are production
# [ ] Supabase storage key is service role key (not anon key)
# [ ] All API keys are kept secret
# [ ] File permissions set to 600 (chmod 600 .env.production)
# [ ] .env.production is in .gitignore
# [ ] Backup of .env.production stored securely (password manager)

# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================
# For Vercel:
#   - Set these variables in Vercel dashboard (Settings → Environment Variables)
#   - Select "Production" environment
#   - Never commit this file to git
#
# For Self-Hosted:
#   - Copy this file to .env.production
#   - Fill in all values
#   - Set file permissions: chmod 600 .env.production
#   - Load with: export $(cat .env.production | xargs)
#
# Generate Secrets:
#   openssl rand -hex 32
#
# Verify Setup:
#   node scripts/verify-env.js
