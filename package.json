{
  "name": "imboni-serve",
  "version": "2.0.1",
  "scripts": {
    "dev": "cross-env NEXT_DISABLE_SWC_NATIVE_PATCH=1 next dev",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 NEXT_TELEMETRY_DISABLED=1 next build",
    "build:local": "cross-env BUILD_PROFILE=local NODE_OPTIONS=--max-old-space-size=8192 NEXT_TELEMETRY_DISABLED=1 next build",
    "build:ci": "cross-env BUILD_PROFILE=ci NODE_OPTIONS=--max-old-space-size=12288 NEXT_TELEMETRY_DISABLED=1 next build",
    "start": "next start",
    "seed": "tsx prisma/seed.ts",
    "seed:qr-templates": "tsx scripts/seed-qr-templates.ts",
    "db:push": "npx prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "plans:update": "tsx scripts/updatePlans.ts",
    "pricing:validate": "tsx scripts/validate-pricing.ts",
    "db:studio": "npx prisma studio",
    "prisma:generate:safe": "powershell -ExecutionPolicy Bypass -File .\\scripts\\fix-prisma-generate.ps1",
    "test:dt": "tsx tests/formatDateTimeRW.test.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:edge": "jest tests/edge-cases",
    "test:integration": "jest tests/integration",
    "test:ci": "jest --ci --coverage --maxWorkers=2"
  },
