  payerEmail               String?
  payerPhone               String?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  paidAt                   DateTime?
  expiryAt                 DateTime?
  webhookSignature         String?
  webhookTimestamp         BigInt?
  webhookVerified          Boolean                  @default(false)
  rawRequest               Json?
  rawCallback              Json?
  rawStatus                Json?
