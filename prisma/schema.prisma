// ========================================
// GAME CHANGER FEATURES
// ========================================

// Feature 1: Split Bill Payments
model SalePayment {
  id                   String            @id @default(cuid())
  saleId               String
  payerName            String?
  payerPhone           String?
  payerEmail           String?
  amountCents          Int
  itemIds              String[] // Array of SaleItem IDs assigned to this payer
  status               SalePaymentStatus @default(PENDING)
  paymentTransactionId String?           @unique
  paidAt               DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  sale               Sale                @relation(fields: [saleId], references: [id], onDelete: Cascade)
  paymentTransaction PaymentTransaction? @relation(fields: [paymentTransactionId], references: [id])

  @@index([saleId])
  @@index([status])
}

model SplitPaymentWhatsAppTrigger {
  id                 String   @id @default(cuid())
  saleId             String   @unique
  triggeredAt        DateTime @default(now())
  tablePersonCount   Int
  unpaidBalanceCents Int
  recipientPhone     String
  linkSent           String
  createdAt          DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

// Feature 2: Digital Tipping
model StaffTip {
  id                   String         @id @default(cuid())
  saleId               String
  staffId              String
  businessId           String
  amountCents          Int
  platformFeeCents     Int // 2-3% platform fee
  netToStaffCents      Int
  tipType              String         @default("ROUND_UP") // ROUND_UP, CUSTOM, PERCENTAGE
  status               StaffTipStatus @default(PENDING)
  paymentTransactionId String?        @unique
  seatId               String?
  paidAt               DateTime?
  payoutAt             DateTime? // When staff withdrew
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  sale               Sale                @relation(fields: [saleId], references: [id], onDelete: Cascade)
  staff              User                @relation(fields: [staffId], references: [id])
  business           Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  paymentTransaction PaymentTransaction? @relation(fields: [paymentTransactionId], references: [id])
  seat               Seat?               @relation("SeatTips", fields: [seatId], references: [id])

  @@index([staffId, status])
  @@index([businessId])
  @@index([saleId])
}

model TipChoice {
  id                   String   @id @default(cuid())
  saleId               String
  accepted             Boolean
  suggestedAmountCents Int
  createdAt            DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([accepted])
}

// Feature 4: Supplier Insights Subscription
model SupplierInsightsSubscription {
  id         String               @id @default(cuid())
  supplierId String               @unique
  tier       SupplierInsightsTier @default(BASIC)
  isActive   Boolean              @default(true)
  startDate  DateTime             @default(now())
  expiresAt  DateTime
  priceCents Int
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId, isActive])
}

// Unified Fee Management System
model PlatformFeeConfig {
  id             String    @id @default(cuid())
  feeType        String    @unique // BUSINESS_COMMISSION, SUPPLIER_FEE, etc.
  feePercent     Float
  minAmountCents Int?
  maxAmountCents Int?
  isActive       Boolean   @default(true)
  description    String?
  effectiveFrom  DateTime  @default(now())
  effectiveUntil DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([feeType, isActive])
  @@index([effectiveFrom, effectiveUntil])
}

// Menu Interaction & Analytics Event Log
model EventLog {
  id         String   @id @default(cuid())
  businessId String?
  sessionId  String? // Table session ID for group ordering context
  customerId String?
  type       String // view_item, add_to_cart, ai_question, recommendation_shown, recommendation_clicked, etc.
  entityType String? // MenuItem, Sale, etc.
  entityId   String? // ID of the entity (menuItemId, saleId, etc.)
  metadata   Json? // Flexible field for additional context
  createdAt  DateTime @default(now())

  @@index([businessId, type, createdAt])
  @@index([type, createdAt])
  @@index([entityType, entityId])
  @@index([sessionId])
}

// QR Menu Builder - Template definitions
model QrTemplate {
  id          String   @id @default(cuid())
  name        String
  category    String // menu_poster, table_tent, coaster, sticker, aframe, business_card
  svgTemplate String   @db.Text
  previewUrl  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  designs QrDesign[]

  @@index([category])
}

// QR Menu Builder - User-created designs
model QrDesign {
  id         String   @id @default(cuid())
  businessId String
  templateId String
  name       String
  customData Json // { logo, primaryColor, message, qrType, tableNumber? }
  previewUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  template QrTemplate @relation(fields: [templateId], references: [id])
  qrCode   QrCode?

  @@index([businessId])
  @@index([templateId])
}

// QR Menu Builder - Generated QR codes
model QrCode {
  id            String    @id @default(cuid())
  businessId    String
  designId      String    @unique
  token         String    @unique
  type          String // menu, store, table
  targetUrl     String
  metadata      Json? // { tableNumber? }
  scanCount     Int       @default(0)
  lastScannedAt DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  design   QrDesign @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([businessId])
}

// Phase 2A: AI Usage Tracking
model AIUsageLog {
  id          String   @id @default(cuid())
  businessId  String
  feature     String // 'scanner', 'site_builder', 'insights', 'menu_description'
  creditsUsed Int
  tokensUsed  Int? // OpenAI tokens consumed
  costUSD     Float? // Actual OpenAI cost
  metadata    Json? // Additional context
  createdAt   DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([feature, createdAt])
}

// Phase 2A: Site Builder Subscription
model SiteBuilderSubscription {
  id                 String   @id @default(cuid())
  businessId         String   @unique
  tier               String   @default("FREE") // FREE, PRO
  customDomain       String?
  customDomainActive Boolean  @default(false)
  aiGenerationsUsed  Int      @default(0)
  aiGenerationsLimit Int      @default(3) // FREE: 3, PRO: 50
  isPublished        Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

// Phase 2A: Discovery Marketplace Subscription
model DiscoverySubscription {
  id           String    @id @default(cuid())
  businessId   String    @unique
  tier         String    @default("FREE") // FREE, FEATURED, PREMIUM
  boostedUntil DateTime? // For temporary boosts
  commission   Float     @default(10.0) // Commission percentage
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([tier])
}

// QR Ordering Enhancement: Waiter Call System
model WaiterCall {
  id             String    @id @default(cuid())
  tableId        String
  sessionId      String?
  businessId     String
  reason         String // 'water', 'assistance', 'bill', 'other'
  customMessage  String?
  status         String    @default("pending") // 'pending', 'acknowledged', 'resolved'
  priority       Int       @default(1) // 1=normal, 2=urgent
  createdAt      DateTime  @default(now())
  acknowledgedAt DateTime?
  acknowledgedBy String? // Staff user ID
  resolvedAt     DateTime?
  resolvedBy     String? // Staff user ID
  // Kitchen -> Customer messaging support (minimal addition)
  orderId        String?
  direction      String    @default("customer_to_kitchen") // "customer_to_kitchen" | "kitchen_to_customer"

  table    Table         @relation(fields: [tableId], references: [id], onDelete: Cascade)
  session  TableSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  order    Sale?         @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([tableId, status])
  @@index([businessId, status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([orderId, createdAt])
}

// Global Currency System: Exchange Rates
model CurrencyExchangeRate {
  id           String    @id @default(cuid())
  fromCurrency String // ISO 4217 currency code (e.g., RWF, USD)
  toCurrency   String // ISO 4217 currency code
  rate         Decimal   @db.Decimal(12, 6) // Exchange rate (6 decimal precision)
  source       String    @default("manual") // 'manual', 'api', 'bank'
  validFrom    DateTime  @default(now())
  validUntil   DateTime? // Null means current/active
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([fromCurrency, toCurrency, validFrom])
  @@index([fromCurrency, toCurrency, validFrom])
}

// Global Currency System: Supported Currencies
model SupportedCurrency {
  code          String   @id // ISO 4217 code (RWF, USD, EUR, etc.)
  name          String // Full name (Rwandan Franc, US Dollar, etc.)
  symbol        String // Currency symbol (FRw, $, €, etc.)
  decimalDigits Int      @default(2) // Number of decimal places
  isActive      Boolean  @default(true)
  countries     String[] // Countries where this currency is used
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Business Revenue Scanner: Scan History
model BusinessScan {
  id             String   @id @default(cuid())
  businessId     String
  score          Int // 0-100 revenue optimization score
  primaryIssue   String?
  criticalIssues Json? // Array of critical issues
  mediumIssues   Json? // Array of medium priority issues
  opportunities  Json? // Array of opportunities
  quickWins      Json? // Array of quick win actions
  aiCreditsUsed  Int      @default(5)
  scanDurationMs Int? // How long the scan took
  createdAt      DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([score])
}

// Optimization Memory: Track recommendations and their outcomes
model OptimizationRecommendation {
  id              String                @id @default(cuid())
  businessId      String
  source          String // "BUSINESS_SCANNER" | "AI_INSIGHTS" | "AUTOPILOT" | "MANUAL"
  category        String // "MENU" | "PRICING" | "INVENTORY" | "MARKETING" | "OPERATIONS"
  title           String // Short title of recommendation
  description     String // Detailed description
  priority        String                @default("MEDIUM") // "HIGH" | "MEDIUM" | "LOW"
  estimatedImpact String? // "High revenue increase" | "Reduce costs by 15%"
  effort          String? // "LOW" | "MEDIUM" | "HIGH"
  status          String                @default("PENDING") // "PENDING" | "IN_PROGRESS" | "COMPLETED" | "DISMISSED" | "FAILED"
  dismissedReason String?
  metadata        Json? // Source-specific data (scan results, KPIs, etc.)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  completedAt     DateTime?
  completedBy     String?
  business        Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  actions         OptimizationAction[]
  outcomes        OptimizationOutcome[]

  @@index([businessId, status, createdAt])
  @@index([source, category])
  @@index([priority, status])
}

// Optimization Action: Specific actions taken for a recommendation
model OptimizationAction {
  id               String                     @id @default(cuid())
  recommendationId String
  actionType       String // "MENU_UPDATE" | "PRICE_CHANGE" | "ITEM_HIDE" | "ITEM_SHOW" | "MANUAL"
  description      String
  beforeState      Json? // State before action (e.g., old price, old visibility)
  afterState       Json? // State after action (e.g., new price, new visibility)
  executedBy       String? // User ID who executed
  executedAt       DateTime                   @default(now())
  isReversible     Boolean                    @default(true)
  reversedAt       DateTime?
  reversedBy       String?
  metadata         Json? // Action-specific data
  recommendation   OptimizationRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@index([recommendationId, executedAt])
  @@index([actionType])
}

// Optimization Outcome: Measure impact of recommendations
model OptimizationOutcome {
  id                String                     @id @default(cuid())
  recommendationId  String
  businessId        String
  metricType        String // "REVENUE" | "ORDERS" | "CONVERSION" | "AOV" | "CUSTOM"
  metricName        String // "Daily Revenue" | "Order Count" | "Conversion Rate"
  beforeValue       Float? // Metric value before action
  afterValue        Float? // Metric value after action
  changePercent     Float? // Calculated percentage change
  measurementPeriod String // "7_DAYS" | "14_DAYS" | "30_DAYS"
  measuredAt        DateTime                   @default(now())
  metadata          Json? // Additional context
  business          Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  recommendation    OptimizationRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@index([recommendationId, measuredAt])
  @@index([businessId, metricType])
}

// Global Timezone System: Supported Timezones
model SupportedTimezone {
  id          String   @id // IANA timezone identifier (Africa/Kigali, etc.)
  name        String // Display name (Central Africa Time, etc.)
  utcOffset   String // UTC offset (+02:00, etc.)
  countryCode String? // ISO country code (RW, US, etc.)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ============================================
// REFERRAL & REWARDS SYSTEM
// ============================================

// Tracks individual referral link clicks and conversions
model ReferralClick {
  id             String    @id @default(cuid())
  referralLinkId String
  ipAddress      String?
  userAgent      String?
  deviceId       String? // Browser fingerprint
  clickedAt      DateTime  @default(now())
  convertedAt    DateTime? // When they signed up/ordered
  customerId     String? // Set when conversion happens
  orderId        String? // First order that converted

  referralLink ReferralLink @relation(fields: [referralLinkId], references: [id], onDelete: Cascade)

  @@index([referralLinkId, clickedAt])
  @@index([deviceId])
  @@index([ipAddress])
}

// Tracks all types of referral rewards (welcome bonus, commission, etc.)
model ReferralReward {
  id              String    @id @default(cuid())
  referralLinkId  String
  customerId      String? // Who earned the reward
  tier            String    @default("TIER_2") // TIER_1 (B2B), TIER_2 (Customer), TIER_3 (Casual)
  type            String // "WELCOME_BONUS", "COMMISSION", "MILESTONE", "TABLE_INVITE"
  amountCents     Int
  status          String    @default("EARNED") // EARNED, VALIDATED, WITHDRAWABLE, PAID, REJECTED
  triggeredBy     String? // Order ID or event that triggered reward
  description     String? // Human-readable description
  metadata        Json? // Additional context
  lockUntil       DateTime? // Lock period (7 days for validation)
  createdAt       DateTime  @default(now())
  validatedAt     DateTime? // When order was confirmed (not refunded)
  withdrawableAt  DateTime? // When lock period ended
  approvedAt      DateTime?
  approvedBy      String? // Admin user ID
  paidAt          DateTime?
  rejectedAt      DateTime?
  rejectionReason String?

  referralLink ReferralLink @relation(fields: [referralLinkId], references: [id], onDelete: Cascade)

  @@index([referralLinkId, status])
  @@index([customerId, status])
  @@index([type, status])
  @@index([tier, status])
  @@index([lockUntil])
  @@index([createdAt])
}

// Monthly aggregated earnings for customer referrals (Tier 2 & 3)
model AffiliateEarnings {
  id              String    @id @default(cuid())
  referralLinkId  String
  month           String // "2026-04" format
  totalEarnings   Int       @default(0) // In cents (fixed rewards, not percentage)
  orderCount      Int       @default(0)
  conversionCount Int       @default(0)
  tier            String    @default("TIER_2") // TIER_2 (Customer), TIER_3 (Casual)
  status          String    @default("PENDING") // PENDING, APPROVED, PAID
  paidAt          DateTime?
  paymentMethod   String? // "MOMO", "BANK_TRANSFER"
  paymentRef      String? // Transaction reference
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  referralLink ReferralLink @relation(fields: [referralLinkId], references: [id], onDelete: Cascade)

  @@unique([referralLinkId, month])
  @@index([referralLinkId, status])
  @@index([month])
}

// Table session invite tracking (for "Share Your Table" feature)
model TableSessionInvite {
  id           String    @id @default(cuid())
  sessionId    String
  inviterId    String // SessionParticipant ID who invited
  inviteeId    String? // SessionParticipant ID who joined (null until accepted)
  inviteCode   String    @unique
  status       String    @default("PENDING") // PENDING, ACCEPTED, EXPIRED
  rewardCents  Int       @default(50000) // 500 RWF default
  rewardStatus String    @default("PENDING") // PENDING, EARNED, PAID
  expiresAt    DateTime // Invites expire after session ends
  createdAt    DateTime  @default(now())
  acceptedAt   DateTime?

  session TableSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  inviter SessionParticipant  @relation("InviterInvites", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee SessionParticipant? @relation("InviteeInvites", fields: [inviteeId], references: [id], onDelete: SetNull)

  @@index([inviteCode])
  @@index([sessionId, status])
  @@index([inviterId])
}

// Fraud detection log for abuse prevention
model FraudDetectionLog {
  id          String   @id @default(cuid())
  entityType  String // "REFERRAL_CLICK", "SIGNUP", "ORDER"
  entityId    String
  riskScore   Float // 0.0 to 1.0
  riskFactors Json // Array of detected risk factors
  action      String // "ALLOWED", "FLAGGED", "BLOCKED"
  ipAddress   String?
  deviceId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([riskScore])
  @@index([action])
  @@index([createdAt])
}

// ============================================
// A/B TESTING (EXPERIMENTS)
// ============================================

enum ABTestStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

enum ABEventType {
  VIEW
  CLICK
  ORDER
  REVENUE
  CUSTOM
}

model ABTest {
  id              String       @id @default(cuid())
  businessId      String
  name            String
  menuItemId      String?
  status          ABTestStatus @default(DRAFT)
  startAt         DateTime?
  endAt           DateTime?
  winnerVariantId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  menuItem      MenuItem?      @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  winnerVariant ABVariant?     @relation("WinnerVariant", fields: [winnerVariantId], references: [id])
  variants      ABVariant[]
  assignments   ABAssignment[]
  events        ABEvent[]

  @@index([businessId, status])
  @@index([menuItemId])
}

model ABVariant {
  id             String   @id @default(cuid())
  testId         String
  name           String
  description    String?
  trafficPercent Int? // 0-100; if null, split equally
  changes        Json? // e.g., { "priceCents": 200000 }
  createdAt      DateTime @default(now())

  test         ABTest         @relation(fields: [testId], references: [id], onDelete: Cascade)
  winningTests ABTest[]       @relation("WinnerVariant")
  assignments  ABAssignment[]
  events       ABEvent[]

  @@index([testId])
}

model ABAssignment {
  id        String   @id @default(cuid())
  testId    String
  variantId String
  visitorId String // anonymous or cookie-based id
  userId    String? // if authenticated
  createdAt DateTime @default(now())

  test    ABTest    @relation(fields: [testId], references: [id], onDelete: Cascade)
  variant ABVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([testId, visitorId])
  @@index([testId, variantId])
}

model ABEvent {
  id         String      @id @default(cuid())
  testId     String
  variantId  String
  type       ABEventType
  valueCents Int? // for REVENUE or numeric metrics
  metadata   Json?
  createdAt  DateTime    @default(now())

  test    ABTest    @relation(fields: [testId], references: [id], onDelete: Cascade)
  variant ABVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([testId, variantId, type])
  @@index([createdAt])
}

model SupplierRecommendationLog {
  id                  String   @id @default(cuid())
  businessId          String
  userId              String
  supplierId          String
  productName         String?
  action              String // 'clicked', 'ordered', 'dismissed', 'approved', 'modified'
  recommendationScore Float?
  metadata            Json?
  createdAt           DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([businessId, supplierId])
  @@index([userId, action])
  @@index([createdAt])
}

model SupplierPerformanceCache {
  id                  String   @id @default(cuid())
  supplierId          String   @unique
  avgDeliveryDays     Float?
  orderCompletionRate Float?
  avgRating           Float?
  totalOrders         Int      @default(0)
  lastCalculated      DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([lastCalculated])
}

// ============================================
// CONTACT MANAGEMENT SYSTEM (CMS)
// Relationship Intelligence for Hospitality Ecosystem
// ============================================

enum ContactType {
  CLIENT // Restaurant/Hotel customer
  SUPPLIER // Supplier representative
  STAFF // Internal staff member
  CUSTOMER // End customer (diner)
  PARTNER // Business partner
  LEAD // Potential client
}

enum ContactStatus {
  ACTIVE
  INACTIVE
  LEAD
  BLOCKED
  ARCHIVED
}

enum OrganizationType {
  RESTAURANT
  HOTEL
  SUPPLIER
  DISTRIBUTOR
  MANUFACTURER
  SERVICE_PROVIDER
  OTHER
}

enum RelationshipType {
  WORKS_AT // Contact works at Organization
  OWNS // Contact owns Organization
  MANAGES // Contact manages Organization
  SUPPLIES_TO // Supplier supplies to Business
  PARTNERS_WITH // Business partnership
  REPORTS_TO // Staff reporting structure
  CONTACTS // General contact relationship
  REFERRED_BY // Referral relationship
  CUSTOMER_OF // Customer of business
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  ORDER_PLACED
  ORDER_DELIVERED
  PAYMENT_RECEIVED
  WHATSAPP_MESSAGE
  SYSTEM_EVENT
  TASK_CREATED
  TASK_COMPLETED
  CONTRACT_SIGNED
  COMPLAINT
  FEEDBACK
}

// Core Contact Entity - represents individual people
model Contact {
  id String @id @default(cuid())

  // Basic Information
  name           String
  phone          String?
  email          String?
  alternatePhone String?
  whatsappNumber String?

  // Classification
  type     ContactType
  status   ContactStatus @default(ACTIVE)
  role     String? // e.g., "Owner", "Manager", "Procurement Officer"
  jobTitle String?

  // Location
  city     String?
  district String?
  country  String  @default("RW")
  address  String?

  // Metadata
  tags            String[] @default([])
  notes           String?
  profileImageUrl String?

  // Ownership & Permissions
  businessId String // Which business owns this contact
  createdBy  String? // User who created this contact
  assignedTo String? // User responsible for this contact

  // Auto-creation tracking
  source   String? // "manual", "registration", "order", "whatsapp", "import"
  sourceId String? // ID from source system

  // Analytics fields
  lastContactedAt DateTime?
  lastActivityAt  DateTime?
  activityScore   Float     @default(0) // 0-100 engagement score

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  business Business @relation("BusinessContacts", fields: [businessId], references: [id], onDelete: Cascade)

  // Relationships this contact is part of
  relationshipsFrom ContactRelationship[] @relation("RelationshipFrom")
  relationshipsTo   ContactRelationship[] @relation("RelationshipTo")

  // Activities
  activities ContactActivity[]

  // Organization memberships
  organizationMemberships OrganizationMember[]

  // Custom fields (extensible JSON)
  customFields Json?

  @@unique([businessId, phone])
  @@index([businessId, type])
  @@index([businessId, status])
  @@index([email])
  @@index([phone])
  @@index([tags])
  @@index([lastActivityAt])
  @@index([createdAt])
}

// Organization Entity - represents businesses/companies
model ContactOrganization {
  id String @id @default(cuid())

  // Basic Information
  name        String
  type        OrganizationType
  description String?

  // Contact Details
  phone   String?
  email   String?
  website String?

  // Location
  address   String?
  city      String?
  district  String?
  country   String  @default("RW")
  latitude  Float?
  longitude Float?

  // Business Details
  industry           String?
  taxId              String? // TIN number
  registrationNumber String?

  // Metadata
  tags    String[] @default([])
  notes   String?
  logoUrl String?

  // Ownership
  businessId String // Which business in Imboni owns this record

  // Analytics
  totalRevenue  Int       @default(0) // In cents
  totalOrders   Int       @default(0)
  lastOrderDate DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  business      Business              @relation("BusinessOrganizations", fields: [businessId], references: [id], onDelete: Cascade)
  members       OrganizationMember[]
  relationships ContactRelationship[] @relation("OrganizationRelationships")

  // Custom fields
  customFields Json?

  @@index([businessId, type])
  @@index([businessId, name])
  @@index([createdAt])
}

// Organization Membership - links Contacts to Organizations
model OrganizationMember {
  id String @id @default(cuid())

  contactId      String
  organizationId String

  role      String? // Role within organization
  isPrimary Boolean @default(false) // Primary contact for org

  startDate DateTime?
  endDate   DateTime?
  isActive  Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact      Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization ContactOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([contactId, organizationId])
  @@index([organizationId])
  @@index([contactId])
}

// Relationship Engine - the heart of the CMS
model ContactRelationship {
  id String @id @default(cuid())

  // Relationship participants
  fromContactId String? // Can be null if org-to-org
  toContactId   String? // Can be null if org-to-org
  fromOrgId     String?
  toOrgId       String?

  // Relationship details
  relationshipType RelationshipType
  strength         Float            @default(50) // 0-100 relationship strength

  // Context
  businessId     String // Which business owns this relationship
  organizationId String? // Optional org context

  // Metadata
  notes    String?
  metadata Json? // Contract info, terms, etc.

  // Status
  isActive  Boolean   @default(true)
  startDate DateTime?
  endDate   DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  business     Business             @relation("BusinessRelationships", fields: [businessId], references: [id], onDelete: Cascade)
  fromContact  Contact?             @relation("RelationshipFrom", fields: [fromContactId], references: [id], onDelete: Cascade)
  toContact    Contact?             @relation("RelationshipTo", fields: [toContactId], references: [id], onDelete: Cascade)
  organization ContactOrganization? @relation("OrganizationRelationships", fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([businessId, relationshipType])
  @@index([fromContactId])
  @@index([toContactId])
  @@index([fromOrgId])
  @@index([toOrgId])
  @@index([isActive])
}

// Activity Log - tracks all interactions and events
model ContactActivity {
  id String @id @default(cuid())

  contactId  String
  businessId String

  // Activity details
  activityType ActivityType
  title        String?
  description  String

  // Source tracking
  source   String  @default("manual") // manual, whatsapp, system, api, order
  sourceId String? // Reference to source entity

  // User tracking
  performedBy String? // User ID who performed action

  // Metadata
  metadata    Json?
  attachments String[] @default([])

  // Timestamps
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())

  // Relations
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  business Business @relation("BusinessContactActivities", fields: [businessId], references: [id], onDelete: Cascade)

  @@index([contactId, timestamp])
  @@index([businessId, activityType])
  @@index([timestamp])
  @@index([source, sourceId])
}

// Contact Segment - for smart filtering and grouping
model ContactSegment {
  id String @id @default(cuid())

  businessId  String
  name        String
  description String?

  // Segment criteria (stored as JSON query)
  criteria Json // e.g., { "type": "SUPPLIER", "city": "Kigali", "tags": ["verified"] }

  // Metadata
  color String?
  icon  String?

  // Auto-update
  isAutoUpdate Boolean   @default(true) // Auto-update membership
  lastUpdated  DateTime?

  // Stats
  memberCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation("BusinessContactSegments", fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

// Contact Tag - for flexible categorization
model ContactTag {
  id String @id @default(cuid())

  businessId  String
  name        String
  color       String?
  description String?

  usageCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation("BusinessContactTags", fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, name])
  @@index([businessId])
}

// ============================================
// IN-APP SUPPORT MESSAGING
// ============================================

enum SupportStatus {
  OPEN
  PENDING
  RESOLVED
}

enum SupportPriority {
  LOW
  NORMAL
  HIGH
}

enum SupportSenderType {
  USER
  STAFF
  SYSTEM
}

model SupportConversation {
  id            String          @id @default(cuid())
  businessId    String
  createdById   String
  assignedToId  String?
  status        SupportStatus   @default(OPEN)
  priority      SupportPriority @default(NORMAL)
  subject       String?
  lastMessageAt DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  business   Business @relation("BusinessSupportConversations", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy  User     @relation("SupportConversationsCreatedBy", fields: [createdById], references: [id])
  assignedTo User?    @relation("SupportConversationsAssignedTo", fields: [assignedToId], references: [id])

  messages SupportMessage[]

  @@index([businessId, status, updatedAt])
  @@index([createdById, updatedAt])
  @@index([assignedToId, status])
}

model SupportMessage {
  id                  String            @id @default(cuid())
  conversationId      String
  senderUserId        String?
  senderType          SupportSenderType
  body                String
  createdAt           DateTime          @default(now())
  readAt              DateTime?
  attachmentUrl       String?
  attachmentMimeType  String?
  attachmentSizeBytes Int?

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser   User?               @relation("SupportMessagesSentBy", fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([senderType, createdAt])
}

model SupportCannedReply {
  id         String   @id @default(cuid())
  businessId String
  title      String
  body       String
  shortcut   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation("BusinessSupportCannedReplies", fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, isActive])
  @@index([businessId, shortcut])
}

// ============================================
// TAP & LEAVE™ SYSTEM
// ============================================

// DiningSessionSlip - Live order tracking during dining session
model DiningSessionSlip {
  id         String   @id @default(cuid())
  slipNumber String   @unique
  sessionId  String   @unique
  businessId String
  tableId    String?

  // Session State
  status String @default("active") // "active" | "checkout_initiated" | "bill_finalized" | "payment_triggered" | "awaiting_confirmation" | "checkout_completed" | "closed"

  // Financial Tracking (Live)
  runningSubtotalCents Int @default(0)
  runningVatCents      Int @default(0)
  runningTotalCents    Int @default(0)
  finalBillCents       Int?

  // Tax Configuration
  taxMode String @default("EXCLUSIVE") // "INCLUSIVE" | "EXCLUSIVE"
  taxRate Float  @default(18.0)

  // Timestamps
  sessionStartedAt     DateTime  @default(now())
  lastOrderAt          DateTime?
  checkoutInitiatedAt  DateTime?
  billFinalizedAt      DateTime?
  paymentTriggeredAt   DateTime?
  checkoutCompletedAt  DateTime?
  closedAt             DateTime?

  // Metadata
  orderCount Int   @default(0)
  itemCount  Int   @default(0)
  metadata   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session TableSession            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  business Business               @relation("BusinessDiningSessionSlips", fields: [businessId], references: [id], onDelete: Cascade)
  table   Table?                  @relation("TableDiningSessionSlips", fields: [tableId], references: [id], onDelete: SetNull)
  items   DiningSessionSlipItem[]
  events  CheckoutEvent[]

  @@index([businessId])
  @@index([status])
  @@index([businessId, status])
  @@index([sessionStartedAt])
}

// DiningSessionSlipItem - Line items in dining session with kitchen status
model DiningSessionSlipItem {
  id         String @id @default(cuid())
  slipId     String
  saleId     String
  saleItemId String

  // Item Details (denormalized for speed)
  itemName        String
  quantity        Int
  unitPriceCents  Int
  totalPriceCents Int

  // Kitchen Status
  kitchenStatus     String?   @default("pending") // "pending" | "accepted" | "preparing" | "almost_ready" | "ready" | "served"
  kitchenReleasedAt DateTime?
  kitchenReadyAt    DateTime?
  servedAt          DateTime?

  // Metadata
  notes           String?
  instructionTags String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slip     DiningSessionSlip @relation(fields: [slipId], references: [id], onDelete: Cascade)
  sale     Sale              @relation("SaleDiningSlipItems", fields: [saleId], references: [id], onDelete: Cascade)
  saleItem SaleItem          @relation("SaleItemDiningSlipItems", fields: [saleItemId], references: [id], onDelete: Cascade)

  @@index([slipId])
  @@index([saleId])
  @@index([kitchenStatus])
}

// CheckoutEvent - Audit trail for checkout and payment events
model CheckoutEvent {
  id         String @id @default(cuid())
  sessionId  String
  slipId     String?
  businessId String

  // Event Details
  eventType   String @default("session_started") // "session_started" | "order_added" | "checkout_initiated" | "bill_finalized" | "payment_triggered" | "payment_confirmed" | "payment_failed" | "checkout_completed" | "session_closed"
  eventStatus String @default("success") // "success" | "failed" | "pending"

  // Context
  orderId   String?
  paymentId String?
  userId    String?

  // Metadata
  metadata     Json?
  errorMessage String?

  createdAt DateTime @default(now())

  session  TableSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  slip     DiningSessionSlip? @relation(fields: [slipId], references: [id], onDelete: SetNull)
  business Business           @relation("BusinessCheckoutEvents", fields: [businessId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([slipId])
  @@index([businessId])
  @@index([eventType])
  @@index([createdAt])
  @@index([paymentId])
  @@index([eventType, createdAt])
  @@index([businessId, eventType])
}

// ============================================================================
// REVENUE OPERATIONS LAYER
// Professional Marketer System (B2B Acquisition Engine)
// ISOLATED from existing referral systems
// ============================================================================

// Professional Marketer - B2B business acquisition agents
model ProfessionalMarketer {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Identity
  userId String? @unique // Optional link to User table
  name   String
  email  String  @unique
  phone  String  @unique

  // Attribution
  referralCode String  @unique
  qrCodeUrl    String?

  // Status
  status           MarketerStatus @default(ACTIVE)
  suspendedAt      DateTime?
  suspensionReason String?

  // Metadata
  onboardedBy String? // Admin who approved
  notes       String?

  // Relations (NEW TABLES ONLY - NO COUPLING TO EXISTING SYSTEMS)
  wallet             MarketerWallet?
  referredBusinesses MarketerAttribution[]
  commissions        MarketerCommission[]
  payouts            MarketerPayout[]
  riskProfile        MarketerRiskProfile?

  @@index([status])
  @@index([referralCode])
  @@index([email])
}

enum MarketerStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

// Marketer Attribution - IMMUTABLE business-to-marketer mapping
model MarketerAttribution {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Attribution (IMMUTABLE - one business = one marketer only)
  marketerId String
  marketer   ProfessionalMarketer @relation(fields: [marketerId], references: [id], onDelete: Cascade)

  businessId String @unique // Read-only reference - NO FK to Business table

  // Metadata
  attributedAt DateTime @default(now())
  ipAddress    String?
  deviceId     String?
  utmSource    String?
  utmCampaign  String?
  utmMedium    String?
  utmContent   String?

  @@index([marketerId])
  @@index([businessId])
  @@index([attributedAt])
}

// Marketer Wallet - Financial tracking (isolated from DiningCredit)
model MarketerWallet {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  marketerId String               @unique
  marketer   ProfessionalMarketer @relation(fields: [marketerId], references: [id], onDelete: Cascade)

  // Balance (in cents)
  availableBalance Int @default(0)
  pendingBalance   Int @default(0)
  lockedBalance    Int @default(0)

  // Lifetime stats
  totalEarned  Int @default(0)
  totalPaidOut Int @default(0)

  @@index([marketerId])
}

// Marketer Commission - Earnings tracking (isolated from AffiliateCommission)
model MarketerCommission {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  marketerId String
  marketer   ProfessionalMarketer @relation(fields: [marketerId], references: [id], onDelete: Cascade)

  businessId String  // Which business generated this (read-only reference)
  invoiceId  String? // Optional link to Invoice (read-only reference)

  // Commission details
  type        MarketerCommissionType
  amountCents Int
  currency    String         @default("RWF")

  // Lifecycle
  status      MarketerCommissionStatus @default(PENDING)
  lockedUntil DateTime?
  validatedAt DateTime?
  paidAt      DateTime?

  // Metadata
  periodMonth Int?    // For recurring (1-12)
  description String?

  @@index([marketerId, status])
  @@index([businessId])
  @@index([status])
  @@index([createdAt])
}

enum MarketerCommissionType {
  SIGNUP_BONUS
  RECURRING_REVENUE
}

enum MarketerCommissionStatus {
  PENDING
  VALIDATED
  PAID
  VOID
}

// Marketer Payout - Withdrawal requests
model MarketerPayout {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  marketerId String
  marketer   ProfessionalMarketer @relation(fields: [marketerId], references: [id], onDelete: Cascade)

  // Payout details
  amountCents Int
  currency    String @default("RWF")
  method      PayoutMethod

  // Status
  status PayoutStatus @default(PENDING)

  // Processing
  approvedBy   String? // Admin user ID
  approvedAt   DateTime?
  processedAt  DateTime?
  paidAt       DateTime?
  failedAt     DateTime?
  rejectedAt   DateTime?
  rejectedBy   String?
  rejectReason String?

  // External reference
  referenceId      String? @unique
  providerResponse String?

  // Recipient details
  recipientPhone   String?
  recipientBank    String?
  recipientAccount String?

  @@index([marketerId, status])
  @@index([status])
  @@index([createdAt])
}

enum PayoutMethod {
  MTN_MOBILE_MONEY
  AIRTEL_MONEY
  BANK_TRANSFER
}

enum PayoutStatus {
  PENDING
  APPROVED
  PROCESSING
  PAID
  FAILED
  REJECTED
}

// Marketer Risk Profile - Fraud detection (non-blocking)
model MarketerRiskProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  marketerId String               @unique
  marketer   ProfessionalMarketer @relation(fields: [marketerId], references: [id], onDelete: Cascade)

  // Risk scoring
  riskScore Int       @default(0) // 0-100
  riskLevel RiskLevel @default(LOW)

  // Flags
  flags String[] // ["velocity_high", "spike_detected", "new_account"]

  // Stats
  totalPayouts   Int      @default(0)
  avgPayoutCents Int      @default(0)
  lastPayoutAt   DateTime?

  @@index([riskLevel])
  @@index([marketerId])
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// Revenue Event - Append-only audit log
model RevenueEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Event metadata
  type       RevenueEventType
  entityType String // "marketer", "commission", "payout", "wallet"
  entityId   String

  // Payload
  payload Json

  // Context
  triggeredBy String? // User/system that triggered
  ipAddress   String?

  @@index([type, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
}

enum RevenueEventType {
  MARKETER_CREATED
  MARKETER_SUSPENDED
  ATTRIBUTION_RECORDED
  COMMISSION_CREATED
  COMMISSION_VALIDATED
  COMMISSION_PAID
  WALLET_UPDATED
  PAYOUT_REQUESTED
  PAYOUT_APPROVED
  PAYOUT_REJECTED
  PAYOUT_PROCESSING
  PAYOUT_PAID
  PAYOUT_FAILED
  RISK_SCORE_UPDATED
  ALERT_TRIGGERED
}

// Revenue Alert - Admin notifications
model RevenueAlert {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Alert details
  severity AlertSeverity
  type     String // "fraud_risk", "payout_spike", "velocity_high"
  message  String

  // Context
  entityType String
  entityId   String
  metadata   Json?

  // Status
  acknowledged   Boolean   @default(false)
  acknowledgedBy String?
  acknowledgedAt DateTime?

  @@index([severity, acknowledged])
  @@index([createdAt])
  @@index([acknowledged])
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// ========================================
// GROWTH LAYER (Lead Generation)
// ========================================

// Demo Request - Book a demo system
model DemoRequest {
  id          String            @id @default(cuid())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Contact info
  name        String
  businessName String
  contact     String // Phone or email
  message     String?

  // Status
  status      DemoRequestStatus @default(PENDING)
  contactedAt DateTime?
  contactedBy String?
  completedAt DateTime?
  notes       String?

  @@index([status, createdAt])
  @@index([createdAt])
}

enum DemoRequestStatus {
  PENDING
  CONTACTED
  COMPLETED
  CANCELLED
}

// Newsletter Subscriber
model NewsletterSubscriber {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())

  // Contact
  emailOrPhone   String   @unique
  sourcePage     String? // Where they subscribed from
  
  // Status
  isActive       Boolean  @default(true)
  unsubscribedAt DateTime?

  @@index([isActive, createdAt])
  @@index([createdAt])
}

// ====================================================
// OPERATIONAL COORDINATION MODELS (Phase 1)
// ====================================================

// Station - Operational destination for order items
model Station {
  id          String   @id @default(cuid())
  businessId  String
  name        String   // Display name: "Kitchen", "Bar", "Grill", "Pastry"
  code        String   // Unique code: "KITCHEN", "BAR", "GRILL", "PASTRY"
  type        StationType @default(KITCHEN)
  isActive    Boolean  @default(true)
  displayOrder Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  routeRules  RouteRule[]
  slaProfiles SLAProfile[]
  ticketEvents TicketEvent[]

  @@unique([businessId, code])
  @@index([businessId, isActive])
  @@index([businessId, type])
}

// RouteRule - Maps menu items/categories to stations
model RouteRule {
  id          String   @id @default(cuid())
  businessId  String
  stationId   String
  
  // Routing criteria (one must be set)
  menuItemId  String?  // Item-specific override
  category    String?  // Category-level routing
  
  priority    Int      @default(0) // Higher priority wins
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  station     Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)
  menuItem    MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([businessId, isActive])
  @@index([menuItemId])
  @@index([category])
  @@index([stationId])
}

// TicketEvent - Append-only operational event log
model TicketEvent {
  id          String   @id @default(cuid())
  saleId      String
  saleItemId  String?  // Optional: item-level events
  stationId   String?  // Optional: station context
  
  eventType   TicketEventType
  actorId     String?  // User who triggered event
  actorName   String?  // Cached actor name
  
  // Event metadata
  previousState String?
  newState      String?
  metadata      Json?   // Flexible payload for event-specific data
  
  // Phase 3: Deduplication and ordering
  idempotencyKey String?  // Unique key to prevent duplicate events
  sequenceNumber Int?     // Ordering within saleItem
  
  createdAt   DateTime @default(now())

  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleItem    SaleItem? @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  station     Station?  @relation(fields: [stationId], references: [id], onDelete: SetNull)
  actor       User?     @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@unique([saleItemId, idempotencyKey])
  @@index([saleId, createdAt])
  @@index([saleItemId, sequenceNumber])
  @@index([eventType])
  @@index([createdAt])
  @@index([stationId])
  @@index([idempotencyKey])
}

// SLAProfile - Configurable timing thresholds
model SLAProfile {
  id                  String   @id @default(cuid())
  businessId          String
  stationId           String?  // Station-specific, or null for default
  category            String?  // Category-specific, or null for default
  
  warningAfterMinutes Int      @default(8)
  breachAfterMinutes  Int      @default(15)
  
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  business            Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  station             Station? @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@index([businessId, isActive])
  @@index([stationId])
  @@index([category])
}

// ====================================================
// ENUMS FOR OPERATIONAL COORDINATION
// ====================================================

enum StationType {
  KITCHEN
  BAR
  GRILL
  FRYER
  PASTRY
  EXPO
  OTHER
}

enum ItemStatus {
  NEW
  PREPARING
  READY
  DELIVERED
  CANCELED
}

enum MutationType {
  CREATED
  MODIFIED
  REPLACED
  CANCELLED
}

enum ExpoStatus {
  PENDING
  READY_FOR_EXPO
  EXPO_CONFIRMED
  SERVED_CONFIRMED
}

enum TicketEventType {
  ORDER_CREATED
  ORDER_UPDATED
  ITEM_ROUTED
  ITEM_ACCEPTED
  ITEM_PREPARING
  ITEM_READY
  ITEM_DELIVERED
  ITEM_CANCELED
  SLA_WARNING
  SLA_BREACH
  ORDER_COMPLETED
  ORDER_CANCELED
  STATION_CHANGED
  MANUAL_OVERRIDE
  RECONCILIATION
  CONFLICT_DETECTED
  INVALID_TRANSITION
}

// Phase 3: Idempotency tracking for request deduplication
model IdempotencyKey {
  id            String   @id @default(cuid())
  key           String   @unique
  businessId    String
  endpoint      String
  requestBody   Json?
  responseBody  Json?
  statusCode    Int?
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, endpoint])
  @@index([expiresAt])
}
