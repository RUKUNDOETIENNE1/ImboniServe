generator client {
  provider      = "prisma-client-js"
  engineType    = "binary"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                           String                      @id @default(cuid())
  name                         String
  email                        String                      @unique
  emailVerified                DateTime?
  image                        String?
  password                     String
  phone                        String                      @unique
  roles                        UserRole[]                  @default([OWNER])
  primaryBranchId              String?
  whatsappEnabled              Boolean                     @default(false)
  whatsappNumber               String?
  isActive                     Boolean                     @default(true)
  lastLoginAt                  DateTime?
  supplierId                   String?                     @unique
  createdAt                    DateTime                    @default(now())
  updatedAt                    DateTime                    @updatedAt
  businessId                   String?
  affiliateCode                String?                     @unique
  affiliateCookieExpiry        DateTime?
  affiliateEnabled             Boolean                     @default(false)
  referredByAffiliateId        String?
  timezone                     String                      @default("Africa/Kigali")
  locale                       String                      @default("en")
  preferredCurrency            String                      @default("RWF")
  accounts                     Account[]
  affiliate                    Affiliate?                  @relation("AffiliateUser")
  affiliateCommissionsNew      AffiliateCommissionNew[]    @relation("AffiliateCommissions")
  reservations                 Reservation[]
  whatsappMessages             WhatsAppMessage[]
  staffTipsReceived            StaffTip[]
  ownedBusinesses              Business[]                  @relation("BusinessOwner")
  sales                        Sale[]
  sessions                     Session[]
  assignedTables               Table[]                     @relation("TableWaiter")
  business                     Business?                   @relation("BusinessUsers", fields: [businessId], references: [id])
  referredByAffiliate          User?                       @relation("AffiliateReferrals", fields: [referredByAffiliateId], references: [id])
  referrals                    User[]                      @relation("AffiliateReferrals")
  supplier                     Supplier?                   @relation("SupplierUser", fields: [supplierId], references: [id])
  InventoryUpdate              InventoryUpdate[]
  MarketplaceOrder             MarketplaceOrder[]
  loginOtps                    UserLoginOtp[]
  devices                      UserDevice[]
  securityEvents               SecurityEvent[]
  supplierRecommendationLogs   SupplierRecommendationLog[]
  staffRolesCreated            StaffRole[]                 @relation("StaffRoleCreatedBy")
  staffRoleAssignments         UserStaffRole[]
  primaryBranch                Branch?                     @relation(fields: [primaryBranchId], references: [id])
  supportConversationsCreated  SupportConversation[]       @relation("SupportConversationsCreatedBy")
  supportConversationsAssigned SupportConversation[]       @relation("SupportConversationsAssignedTo")
  supportMessagesSent          SupportMessage[]            @relation("SupportMessagesSentBy")
  ticketEvents                 TicketEvent[]
}

model Business {
  id                                String                    @id @default(cuid())
  name                              String
  description                       String?
  address                           String?
  city                              String                    @default("Kigali")
  district                          String?
  country                           String                    @default("RW")
  latitude                          Float?
  longitude                         Float?
  phone                             String
  whatsappNumber                    String?
  ownerId                           String
  planId                            String?
  currency                          String                    @default("RWF")
  timezone                          String                    @default("Africa/Kigali")
  isActive                          Boolean                   @default(true)
  referredByAffiliateId             String?
  whatsappOwnerReportsEnabled       Boolean                   @default(true)
  whatsappClientSlipsEnabled        Boolean                   @default(false)
  whatsappClientSlipsConsent        Boolean                   @default(false)
  whatsappDailyCapClient            Int                       @default(50)
  whatsappMonthlyBudgetCents        Int?
  createdAt                         DateTime                  @default(now())
  updatedAt                         DateTime                  @updatedAt
  defaultDepositPercent             Float                     @default(50.0)
  enableQRInVenue                   Boolean                   @default(false)
  enableQRRemote                    Boolean                   @default(false)
  maxRemoteOrdersPerSlot            Int                       @default(10)
  prepBufferMinutes                 Int                       @default(10)
  requireDepositRemote              Boolean                   @default(true)
  slotDurationMinutes               Int                       @default(30)
  dailyReportEnabled                Boolean                   @default(true)
  dailyReportLocalTime              String                    @default("07:30")
  lastDailyReportSentForDate        String?
  defaultLanguage                   String                    @default("en")
  businessType                      String?
  followUpDay10Done                 Boolean                   @default(false)
  followUpDay13Done                 Boolean                   @default(false)
  followUpDay2Done                  Boolean                   @default(false)
  followUpDay5Done                  Boolean                   @default(false)
  nextAction                        String?
  nextActionCompleted               Boolean                   @default(false)
  nextActionDate                    DateTime?
  salesNotes                        String?
  salesStatus                       String?                   @default("LEAD")
  trialEndDate                      DateTime?
  trialStartDate                    DateTime?
  approvalStatus                    String                    @default("PENDING")
  approvedBy                        String?
  approvedAt                        DateTime?
  rejectionReason                   String?
  riskLevel                         String                    @default("LOW")
  duplicateFlags                    Json?
  cmsNotifyTrending                 Boolean                   @default(false)
  activityLogs                      ActivityLog[]
  affiliateCommissions              AffiliateCommission[]
  affiliateCommissionsNew           AffiliateCommissionNew[]
  branches                          Branch[]
  featureOverrides                  BusinessFeatureOverride[]
  insightReports                    BusinessInsightReport[]
  supportConversations              SupportConversation[]     @relation("BusinessSupportConversations")
  supportCannedReplies              SupportCannedReply[]      @relation("BusinessSupportCannedReplies")
  receivedInvite                    BusinessInvite?           @relation("InviteInvitee")
  sentInvites                       BusinessInvite[]          @relation("InviteReferrer")
  businessProfile                   BusinessProfile?
  businessReviews                   BusinessReview[]
  contentPosts                      ContentPost[]
  customDomains                     CustomDomain[]
  customers                         Customer[]
  customerReferrals                 CustomerReferral[]
  goodsReceivedNotes                GoodsReceivedNote[]
  inventoryItems                    InventoryItem[]
  inventoryUpdates                  InventoryUpdate[]
  inviteCredits                     InviteCredit[]
  loyaltyRules                      LoyaltyRule[]
  marketplaceOrders                 MarketplaceOrder[]
  mediaAssets                       MediaAsset[]
  menuItems                         MenuItem[]
  menuItemCandidates                MenuItemCandidate[]
  menuItemTranslations              MenuItemTranslation[]
  menuSourceDocuments               MenuSourceDocument[]
  outlets                           Outlet[]
  paymentTransactions               PaymentTransaction[]
  pointsLedger                      PointsLedger[]
  postAttributions                  PostAttribution[]
  promotions                        Promotion[]
  purchaseOrders                    PurchaseOrder[]
  reconciliationLogs                ReconciliationLog[]
  reservations                      Reservation[]
  owner                             User                      @relation("BusinessOwner", fields: [ownerId], references: [id])
  plan                              Plan?                     @relation(fields: [planId], references: [id])
  referredByAffiliate               Affiliate?                @relation("BusinessAffiliate", fields: [referredByAffiliateId], references: [id])
  rooms                             Room[]
  sales                             Sale[]
  serviceAreas                      ServiceArea[]
  buyerDocuments                    SmartDiningSlip[]         @relation("BuyerDocuments")
  subscriptions                     Subscription[]
  supplierOrders                    SupplierOrder[]
  tables                            Table[]
  tableSessions                     TableSession[]
  taxConfigurations                 TaxConfiguration[]
  users                             User[]                    @relation("BusinessUsers")
  whatsappMessages                  WhatsAppMessage[]
  freeMonthsGranted                 Int                       @default(0)
  staffTips                         StaffTip[]
  splitPaymentConvenienceFeeEnabled Boolean                   @default(false)
  splitPaymentConvenienceFeePercent Float                     @default(1.0)
  enableDigitalTipping              Boolean                   @default(false)
  taxMode                           TaxMode                   @default(EXCLUSIVE)
  taxRate                           Float                     @default(18.0)
  qrDesigns                         QrDesign[]
  qrCodes                           QrCode[]
  businessViews                     BusinessView[]
  abTests                           ABTest[]
  staffRoles                        StaffRole[]
  userStaffRoles                    UserStaffRole[]

  // AI Credit System (Phase 2A)
  aiCreditsUsed  Int       @default(0)
  aiCreditsLimit Int       @default(20)
  aiResetDate    DateTime?

  // Feature Usage Limits
  qrCodesCount      Int    @default(0)
  cmsPostsThisMonth Int    @default(0)
  storageUsedBytes  BigInt @default(0)

  // Relations for new monetization features
  aiUsageLogs             AIUsageLog[]
  siteBuilderSubscription SiteBuilderSubscription?
  discoverySubscription   DiscoverySubscription?
  businessScans           BusinessScan[]
  waiterCalls             WaiterCall[]

  // Optimization Memory System
  optimizationRecommendations OptimizationRecommendation[]
  optimizationOutcomes        OptimizationOutcome[]

  // Supplier Recommendation System
  supplierRecommendationLogs SupplierRecommendationLog[]

  // Contact Management System
  contacts             Contact[]             @relation("BusinessContacts")
  contactOrganizations ContactOrganization[] @relation("BusinessOrganizations")
  contactRelationships ContactRelationship[] @relation("BusinessRelationships")
  contactActivities    ContactActivity[]     @relation("BusinessContactActivities")
  contactSegments      ContactSegment[]      @relation("BusinessContactSegments")
  contactTags          ContactTag[]          @relation("BusinessContactTags")

  // Tap & Leave™ System
  diningSessionSlips DiningSessionSlip[] @relation("BusinessDiningSessionSlips")
  checkoutEvents     CheckoutEvent[]     @relation("BusinessCheckoutEvents")

  // Operational Coordination (Phase 1)
  stations    Station[]
  routeRules  RouteRule[]
  slaProfiles SLAProfile[]

  // Operational Hardening (Phase 3)
  idempotencyKeys IdempotencyKey[]

  @@map("Restaurant")
}

model Plan {
  id               String  @id @default(cuid())
  name             String
  code             String  @unique
  description      String?
  priceCents       Int
  annualPriceCents Int?
  currency         String  @default("RWF")
  features         Json
  maxUsers         Int?
  maxMenuItems     Int?

  // Phase 2A: Feature limits per plan
  aiCreditsMonthly    Int            @default(50)
  qrCodesLimit        Int? // null = unlimited
  cmsPostsLimit       Int?
  storageGBLimit      Int            @default(5)
  siteBuilderIncluded Boolean        @default(false)
  discoveryFeatured   Boolean        @default(false)
  whatsappIncluded    Boolean        @default(true)
  supportLevel        String         @default("BASIC")
  isActive            Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  businesses          Business[]
  subscriptions       Subscription[]
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  priceCents  Int
  category    String?
  costCents   Int
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  businessId  String

  // Smart Menu Intelligence Fields (backward compatible)
  ingredients     String[] @default([])
  allergens       String[] @default([])
  dietaryTags     String[] @default([]) // e.g., "vegan", "vegetarian", "gluten-free", "halal"
  spiceLevel      String?  @default("none") // "none" | "mild" | "medium" | "hot"
  portionSize     String?  @default("single") // "single" | "shareable"
  prepTimeMinutes Int? // Estimated preparation time
  imageReal       String? // URL to real dish photo

  business     Business              @relation(fields: [businessId], references: [id])
  translations MenuItemTranslation[]
  sales        SaleItem[]
  abTests      ABTest[]
  routeRules   RouteRule[]
}

model Sale {
  id                   String        @id @default(cuid())
  orderNumber          String        @unique
  userId               String
  customerId           String?
  tableId              String?
  totalAmountCents     Int
  paymentMethod        PaymentMethod
  paymentStatus        PaymentStatus @default(PENDING)
  paymentReference     String?
  notes                String?
  isPaid               Boolean       @default(false)
  status               String        @default("ACTIVE")
  kitchenStatus        String?       @default("pending") // "pending" | "accepted" | "preparing" | "almost_ready" | "ready" | "served"
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  businessId           String
  customerName         String?
  customerPhone        String?
  depositCents         Int           @default(0)
  kitchenReleasedAt    DateTime?
  orderSource          OrderSource   @default(WAITER_POS)
  paymentTransactionId String?       @unique
  prepStartedAt        DateTime?
  readyAt              DateTime?
  scheduledAt          DateTime?
  customerConfirmedAt  DateTime?
  outletId             String?
  seatId               String?

  // Kitchen Execution & Group Ordering
  tableSessionId String?
  participantId  String?
  acceptedAt     DateTime? // When kitchen accepted order
  preparingAt    DateTime? // When kitchen started preparing
  almostReadyAt  DateTime? // When marked almost ready
  servedAt       DateTime? // When served to customer

  // Add-to-Order Support
  isAddon       Boolean   @default(false) // Is this an addon to existing order
  parentOrderId String? // Link to original order
  addedAt       DateTime? // When items were added
  syncedAt      DateTime? // When synced from offline

  // Kitchen Dispatch Tracking (Mandatory)
  kitchenDispatchedAt   DateTime?
  kitchenDispatchStatus String?   @default("pending") // "pending" | "dispatched" | "failed"
  kitchenDispatchError  String?

  // Reality Gap Fix: Expo Finalization State (Priority 3)
  expoStatus         ExpoStatus? @default(PENDING)
  readyForExpoAt     DateTime?   // When all stations marked ready
  expoConfirmedAt    DateTime?   // When expo confirmed final state
  servedConfirmedAt  DateTime?   // When serve confirmed to customer

  postAttributions            PostAttribution[]
  parentOrder                 Sale?                        @relation("OrderAddons", fields: [parentOrderId], references: [id], onDelete: SetNull)
  addons                      Sale[]                       @relation("OrderAddons")
  business                    Business                     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer                    Customer?                    @relation(fields: [customerId], references: [id])
  outlet                      Outlet?                      @relation(fields: [outletId], references: [id])
  paymentTransaction          PaymentTransaction?          @relation(fields: [paymentTransactionId], references: [id])
  seat                        Seat?                        @relation("SeatSales", fields: [seatId], references: [id])
  table                       Table?                       @relation(fields: [tableId], references: [id])
  user                        User                         @relation(fields: [userId], references: [id])
  tableSession                TableSession?                @relation(fields: [tableSessionId], references: [id])
  participant                 SessionParticipant?          @relation(fields: [participantId], references: [id])
  items                       SaleItem[]
  smartDiningSlip             SmartDiningSlip?
  salePayments                SalePayment[]
  staffTips                   StaffTip[]
  tipChoices                  TipChoice[]
  splitPaymentWhatsAppTrigger SplitPaymentWhatsAppTrigger?
  diningSlipItems             DiningSessionSlipItem[] @relation("SaleDiningSlipItems")
  waiterCalls                 WaiterCall[]
  ticketEvents                TicketEvent[]

  @@index([orderSource])
  @@index([scheduledAt])
  @@index([businessId, orderSource])
  @@index([outletId])
  @@index([seatId])
  @@index([tableSessionId])
  @@index([participantId])
  @@index([kitchenStatus])
  @@index([businessId, kitchenStatus])
  @@index([businessId, createdAt])
  @@index([paymentStatus, createdAt])
  @@index([parentOrderId])
  @@index([isAddon])
  @@index([businessId, isAddon])
  @@index([kitchenDispatchStatus])
  @@index([businessId, kitchenDispatchStatus])
}

model SaleItem {
  id              String   @id @default(cuid())
  saleId          String
  menuItemId      String
  quantity        Int
  unitPriceCents  Int
  totalPriceCents Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  instructionTags String[] @default([])
  instructions    Json?
  
  // Operational coordination (Phase 1)
  itemStatus      ItemStatus? @default(NEW)
  stationId       String?
  routedAt        DateTime?
  prepStartedAt   DateTime?
  readyAt         DateTime?
  deliveredAt     DateTime?
  
  // Reality Gap Fix: Order Mutation Tracking (Priority 1)
  parentItemId    String?      // Links to original item if this is a modification
  itemVersion     Int          @default(1)
  mutationType    MutationType @default(CREATED)
  replacedBy      String?      // ID of item that replaced this one
  
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id])
  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  diningSlipItems DiningSessionSlipItem[] @relation("SaleItemDiningSlipItems")
  ticketEvents    TicketEvent[]
  
  @@index([itemStatus])
  @@index([stationId])
  @@index([saleId, itemStatus])
  @@index([parentItemId])
  @@index([mutationType])
}

model InventoryItem {
  id            String            @id @default(cuid())
  name          String
  description   String?
  category      String?
  unit          String
  currentStock  Float             @default(0)
  minStockLevel Float             @default(10)
  unitCostCents Int
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  businessId    String
  business      Business          @relation(fields: [businessId], references: [id])
  updates       InventoryUpdate[]
}

model InventoryUpdate {
  id              String        @id @default(cuid())
  inventoryItemId String
  userId          String
  type            String
  quantity        Float
  reason          String?
  notes           String?
  createdAt       DateTime      @default(now())
  businessId      String
  business        Business      @relation(fields: [businessId], references: [id])
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  user            User          @relation(fields: [userId], references: [id])
}

model Subscription {
  id                      String                   @id @default(cuid())
  planId                  String
  status                  String                   @default("ACTIVE")
  amountCents             Int
  currency                String                   @default("RWF")
  paymentMethod           PaymentMethod
  paymentReference        String?
  startDate               DateTime
  endDate                 DateTime
  nextBillingDate         DateTime
  isAutoRenew             Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  businessId              String
  affiliateCommissionsNew AffiliateCommissionNew[]
  invoices                Invoice[]
  paymentTransactions     PaymentTransaction[]
  business                Business                 @relation(fields: [businessId], references: [id])
  plan                    Plan                     @relation(fields: [planId], references: [id])
}

model Invoice {
  id                   String                @id @default(cuid())
  subscriptionId       String
  invoiceNumber        String                @unique
  amountCents          Int
  currency             String                @default("RWF")
  status               String                @default("PENDING")
  paymentMethod        PaymentMethod?
  paymentReference     String?
  dueDate              DateTime
  paidAt               DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  affiliateCommissions AffiliateCommission[]
  subscription         Subscription          @relation(fields: [subscriptionId], references: [id])
}

model WhatsAppMessage {
  id         String   @id @default(cuid())
  userId     String?
  fromNumber String
  toNumber   String
  message    String
  type       String
  status     String   @default("SENT")
  direction  String
  command    String?
  processed  Boolean  @default(false)
  createdAt  DateTime @default(now())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Supplier {
  id                     String                        @id @default(cuid())
  name                   String
  description            String?
  contactName            String
  email                  String                        @unique
  phone                  String
  whatsappNumber         String?
  address                String?
  city                   String                        @default("Kigali")
  district               String?
  country                String                        @default("RW")
  latitude               Float?
  longitude              Float?
  isVerified             Boolean                       @default(false)
  isActive               Boolean                       @default(true)
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt
  leadTimeDays           Int                           @default(2)
  minOrderCents          Int?                          @default(0)
  deliveryCoverageCities Json?
  payoutMethod           String?
  payoutDetails          Json?
  goodsReceivedNotes     GoodsReceivedNote[]
  marketplaceProducts    MarketplaceProduct[]
  purchaseOrders         PurchaseOrder[]
  documents              SmartDiningSlip[]
  deliveries             SupplierDelivery[]
  orders                 SupplierOrder[]
  payouts                SupplierPayout[]
  products               SupplierProduct[]
  user                   User?                         @relation("SupplierUser")
  insightsSubscription   SupplierInsightsSubscription?
  recommendationLogs     SupplierRecommendationLog[]
  performanceCache       SupplierPerformanceCache?
}

model SupplierProduct {
  id               String              @id @default(cuid())
  supplierId       String
  name             String
  description      String?
  category         String?
  unit             String
  unitPriceCents   Int
  minOrderQuantity Float               @default(1)
  isAvailable      Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  orderItems       SupplierOrderItem[]
  supplier         Supplier            @relation(fields: [supplierId], references: [id])
}

model SupplierOrder {
  id               String              @id @default(cuid())
  orderNumber      String              @unique
  supplierId       String
  status           String              @default("PENDING")
  totalAmountCents Int
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  businessId       String
  deliveries       SupplierDelivery[]
  business         Business            @relation(fields: [businessId], references: [id])
  supplier         Supplier            @relation(fields: [supplierId], references: [id])
  items            SupplierOrderItem[]
}

model SupplierOrderItem {
  id              String          @id @default(cuid())
  orderId         String
  productId       String
  quantity        Float
  unitPriceCents  Int
  totalPriceCents Int
  createdAt       DateTime        @default(now())
  order           SupplierOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         SupplierProduct @relation(fields: [productId], references: [id])
}

model SupplierDelivery {
  id          String        @id @default(cuid())
  orderId     String
  supplierId  String
  status      String        @default("SCHEDULED")
  scheduledAt DateTime
  deliveredAt DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  order       SupplierOrder @relation(fields: [orderId], references: [id])
  supplier    Supplier      @relation(fields: [supplierId], references: [id])
}

/// CMS & Discovery Feed Models (additive)
model ContentPost {
  id           String            @id @default(cuid())
  businessId   String
  type         String
  title        String?
  body         String?
  mediaIds     String[]
  comboItems   Json?
  promoMeta    Json?
  status       String            @default("DRAFT")
  publishAt    DateTime?
  expireAt     DateTime?
  targeting    Json?
  createdBy    String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  business     Business          @relation(fields: [businessId], references: [id])
  attributions PostAttribution[]
  engagements  PostEngagement[]

  @@index([businessId, status, publishAt])
  @@index([status, publishAt])
}

model MediaAsset {
  id           String   @id @default(cuid())
  businessId   String
  type         String
  storageKey   String
  width        Int?
  height       Int?
  durationSec  Int?
  thumbnailKey String?
  sizeBytes    Int
  mimeType     String
  createdAt    DateTime @default(now())
  business     Business @relation(fields: [businessId], references: [id])

  @@index([businessId, type])
}

model PostEngagement {
  id        String      @id @default(cuid())
  postId    String
  userId    String?
  type      String
  metadata  Json?
  createdAt DateTime    @default(now())
  post      ContentPost @relation(fields: [postId], references: [id])

  @@index([postId, type])
  @@index([createdAt])
}

model PostAttribution {
  id           String      @id @default(cuid())
  postId       String
  businessId   String
  orderId      String
  channel      String
  attributedAt DateTime    @default(now())
  business     Business    @relation(fields: [businessId], references: [id])
  order        Sale        @relation(fields: [orderId], references: [id])
  post         ContentPost @relation(fields: [postId], references: [id])

  @@index([postId, orderId])
}

model MarketplaceProduct {
  id               String                 @id @default(cuid())
  supplierId       String
  name             String
  description      String?
  category         String?
  unit             String
  unitPriceCents   Int
  minOrderQuantity Float                  @default(1)
  imageUrl         String?
  isAvailable      Boolean                @default(true)
  isFeatured       Boolean                @default(false)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  orderItems       MarketplaceOrderItem[]
  supplier         Supplier               @relation(fields: [supplierId], references: [id])
}

model MarketplaceOrder {
  id                 String                 @id @default(cuid())
  orderNumber        String                 @unique
  userId             String
  status             String                 @default("PENDING")
  totalAmountCents   Int
  paymentMethod      PaymentMethod
  paymentStatus      PaymentStatus          @default(PENDING)
  paymentReference   String?
  deliveryAddress    String?
  deliveryCity       String?
  deliveryDistrict   String?
  deliveryNotes      String?
  notes              String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  businessId         String
  commissionInvoices CommissionInvoice[]
  business           Business               @relation(fields: [businessId], references: [id])
  user               User                   @relation(fields: [userId], references: [id])
  items              MarketplaceOrderItem[]
}

