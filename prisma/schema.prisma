model Table {
  id               String         @id @default(cuid())
  number           String
  capacity         Int            @default(4)
  status           String         @default("AVAILABLE")
  assignedWaiterId String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  businessId       String
  outletId         String?
  qrCode           String?        @unique
  reservations       Reservation[]
  sales              Sale[]
  seats              Seat[]
  tableSessions      TableSession[]
  waiterCalls        WaiterCall[]
  diningSessionSlips DiningSessionSlip[] @relation("TableDiningSessionSlips")
  assignedWaiter     User?               @relation("TableWaiter", fields: [assignedWaiterId], references: [id])
  business           Business            @relation(fields: [businessId], references: [id])
  outlet             Outlet?             @relation(fields: [outletId], references: [id])

  @@unique([businessId, number])
  @@index([outletId])
}

// Table Session for Group Ordering + Tap & Leave™
model TableSession {
  id           String               @id @default(cuid())
  tableId      String
  businessId   String
  status       String               @default("active") // "active" | "closed"
  createdAt    DateTime             @default(now())
  closedAt     DateTime?
  updatedAt    DateTime             @updatedAt
  
  // Tap & Leave™ Checkout Extensions
  checkoutMode         String    @default("standard") // "standard" | "tap_and_leave"
  checkoutStatus       String    @default("active") // "active" | "checkout_initiated" | "bill_finalized" | "payment_triggered" | "awaiting_confirmation" | "checkout_completed"
  checkoutInitiatedAt  DateTime?
  checkoutCompletedAt  DateTime?
  finalBillCents       Int?
  runningTotalCents    Int       @default(0)
  
  table               Table                @relation(fields: [tableId], references: [id])
  business            Business             @relation(fields: [businessId], references: [id])
  participants        SessionParticipant[]
  orders              Sale[]
  waiterCalls         WaiterCall[]
  invites             TableSessionInvite[]
  diningSessionSlip   DiningSessionSlip?
  checkoutEvents      CheckoutEvent[]
  seatSessions        SeatSession[]

  @@index([tableId, status])
  @@index([businessId, status])
  @@index([createdAt])
  @@index([checkoutStatus])
  @@index([businessId, checkoutStatus])
}

// Session Participant for Group Ordering
model SessionParticipant {
  id              String               @id @default(cuid())
  sessionId       String
  tempId          String // Unique device/session identifier (stored in localStorage)
  name            String? // Optional guest name (e.g., "Guest 1")
  joinedAt        DateTime             @default(now())
  createdAt       DateTime             @default(now())
  session         TableSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  orders          Sale[]
  invitesSent     TableSessionInvite[] @relation("InviterInvites")
  invitesReceived TableSessionInvite[] @relation("InviteeInvites")
  seatSession     SeatSession?

  @@unique([sessionId, tempId])
  @@index([sessionId])
  @@index([tempId])
}

