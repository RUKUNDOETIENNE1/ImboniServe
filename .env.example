# Database
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres"

# Auth
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:5432/postgres"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:5432/postgres"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-32-characters-min-secret"
TRIAL_HASH_SECRET="your-trial-hash-secret-min-64-chars"
ALLOW_LEGACY_CREDENTIALS="false"

# Email (SMTP SETUP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-email-app-password"
SMTP_SECURE="true"
SMTP_FROM="Imboni Serve <your-email@gmail.com>"
SUPPORT_EMAIL=support@example.com
ALERT_EMAIL_TO="ops@example.com"

WEATHER_PROVIDER=openweathermap
OPENWEATHER_API_KEY="your-openweather-api-key"

# AI-lite features
AI_SRO_ENABLED=true
SRO_DAYS_WINDOW=14
SRO_SAFETY_STOCK_DAYS=1
DEFAULT_LEAD_TIME_DAYS=2

AI_CPA_ENABLED=true
CPA_THRESHOLD_PERCENT=10

# Twilio (SMS & WhatsApp Messaging)
# Sign up at: https://www.twilio.com/console
# Get your Account SID and Auth Token from the Console Dashboard
# For WhatsApp: Use Twilio's WhatsApp sandbox number or get approved sender
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token_here"
TWILIO_WHATSAPP_NUMBER="whatsapp:+1234567890"  # Twilio sandbox number for testing
TWILIO_PHONE_NUMBER="+1234567890"  # Your Twilio phone number for SMS 

# InTouch Mobile Money (MTN & Airtel) — PRIMARY PAYMENT GATEWAY
# Contact: https://www.intouchpay.co.rw or email their support for API access
# You'll receive: Username, Account Number, and Partner Password
# Customer sees: 5% all-inclusive fee | Gateway cost: 3% | Platform margin: 2%
INTOUCH_API_URL="https://www.intouchpay.co.rw/api"
INTOUCH_USERNAME="your-intouch-username"  # Provided by InTouch support
INTOUCH_ACCOUNT_NO="your-intouch-account-number"  # Your InTouch account number
INTOUCH_PARTNER_PASSWORD="your-intouch-partner-password"  # Partner password from InTouch
INTOUCH_PASSWORD="your-intouch-partner-password"  # Alias supported for compatibility
INTOUCH_CALLBACK_URL="https://imboniserve.com/api/webhooks/intouch"  # Webhook URL for payment status callbacks
# Webhook auth (Basic Auth) — REQUIRED for production webhooks
INTOUCH_WEBHOOK_USERNAME="your-intouch-webhook-username"
INTOUCH_WEBHOOK_PASSWORD="your-intouch-webhook-password"

# IremboPay Payments (Card Payments) — FALLBACK GATEWAY
# Contact: https://www.irembopay.com or reach out to their technical team
# Customer sees: 5% all-inclusive fee | Gateway cost: 3.42% | Platform margin: 1.58%
# Unified naming: use IREMBOPAY_* only
IREMBOPAY_PUBLIC_KEY=""  # Provided by IremboPay
IREMBOPAY_SECRET_KEY=""  # Keep this secret
IREMBOPAY_PAYMENT_ACCOUNT="LOYALTECH-RWF"  # Your payment account ID
IREMBOPAY_PAYMENT_ITEM_CODE=""  # Item code from IremboPay dashboard
IREMBOPAY_API_BASE="https://api.irembopay.com"  # Use https://api.sandbox.irembopay.com for testing
IREMBOPAY_API_VERSION="2"
IREMBOPAY_WEBHOOK_TOLERANCE_SECONDS="300"

# IremboPay Provider (cards) — provider integration
IREMBOPAY_API_URL="https://api.irembo.com"
IREMBOPAY_MERCHANT_ID=""
IREMBOPAY_API_KEY=""
IREMBOPAY_API_SECRET=""
IREMBOPAY_CALLBACK_URL="http://localhost:3000/api/webhooks/irembopay"
IREMBOPAY_RETURN_URL="http://localhost:3000/billing/payment-result"
PAYMENTS_PROVIDER="intouch"  # Primary: intouch | Fallback: irembo

# Slack Alerts
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/XXX/YYY/ZZZ"

# Pusher (Real-time Messaging & Notifications)
# Sign up at: https://dashboard.pusher.com
# Create a new "Channels" app and copy the credentials from the "App Keys" tab
PUSHER_APP_ID=""  # Your Pusher App ID
PUSHER_KEY=""  # Server key (keep secret)
PUSHER_SECRET=""  # Server secret (keep secret)
PUSHER_CLUSTER=""  # e.g., eu, us2, ap1 (from your Pusher dashboard)

# App Settings
APP_URL="http://localhost:3000"
SUPPORT_PHONE="+250700000000"
SUPPORT_WHATSAPP="+250700000000"

# OpenAI (AI Features: Business Insights, Menu Suggestions, etc.)
# Sign up at: https://platform.openai.com
# Go to API Keys section and create a new secret key
# IMPORTANT: Keep this key private and never commit it to version control
OPENAI_API_KEY="sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"  # Starts with sk-proj- or sk-
OPENAI_MODEL_PRIMARY="gpt-4o-mini"  # Primary model (cost-effective)
OPENAI_MODEL_FALLBACK="gpt-4-turbo"  # Fallback if primary fails
OPENAI_COST_INPUT_PER_1K_USD="0.00015"  # Cost per 1K input tokens
OPENAI_COST_OUTPUT_PER_1K_USD="0.00060"  # Cost per 1K output tokens

# Document Information Extraction (DIE) - Azure Document Intelligence (optional)
# If set, Azure is used as the primary extraction provider; OpenAI Vision is the fallback.
# If not set, OpenAI Vision is used directly.
# Get from: Azure Portal -> Document Intelligence resource -> Keys and Endpoint
# Use Key 1 (keep Key 2 for rotation).
# AZURE_DI_ENDPOINT="https://<region>.cognitiveservices.azure.com/"
# AZURE_DI_KEY="your-azure-document-intelligence-key-1"

# DIE tuning (optional - defaults shown)
DIE_MAX_DOC_MB="10"
DIE_PROVIDER_TIMEOUT_MS="30000"

# Pusher (Client-side keys - safe to expose publicly)
# Pusher - optional
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="ap2"
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"

# Enable service worker registration in development (for testing PWA locally)
NEXT_PUBLIC_ENABLE_SW_DEV="true"

# Feature Flags
FEATURE_FLAG_AUTO_CHECK_ENABLED="true"

# Crisp (Customer Support Chat - optional)
# Create your site at https://app.crisp.chat/ → Settings → Website Settings → Setup Instructions
# Copy the Website ID (UUID) and paste below to enable chat (gated by cookie Marketing consent)
NEXT_PUBLIC_CRISP_WEBSITE_ID=""  # e.g., 9f1a2b3c-4d5e-6f70-8a9b-1c2d3e4f5a6b


# Supabase Storage (File Uploads: Images, Videos, Documents)
# Sign up at: https://supabase.com
# Create a new project → Go to Project Settings → API
# Copy the URL and Service Role Key (NOT the anon key)
# Create a public bucket named "media-uploads" in Storage section
STORAGE_PROVIDER="local"  # Use "local" for development, "supabase" for production
SUPABASE_STORAGE_BUCKET="media-uploads"  # Bucket name you created
SUPABASE_STORAGE_URL=""  # e.g., https://xxxxx.supabase.co
SUPABASE_STORAGE_KEY=""  # Service role key (keep secret!)

# Media Upload Limits
MAX_VIDEO_DURATION_SEC="30"
MAX_VIDEO_SIZE_MB="50"
MAX_IMAGE_SIZE_MB="10"

# Smart QR Security
IMBONI_QR_SECRET="your-qr-hmac-secret-min-32-chars"

# Sentry (Error Monitoring & Performance Tracking)
# Sign up at: https://sentry.io
# Create a new project → Go to Settings → Client Keys (DSN)
# Copy the DSN and use it for both server and client
SENTRY_DSN=""  # Your Sentry DSN (starts with https://)
NEXT_PUBLIC_SENTRY_DSN=""  # Same as SENTRY_DSN (for client-side errors)
SENTRY_ENVIRONMENT="development"  # Change to "production" when deploying
SENTRY_TRACES_SAMPLE_RATE="0.1"  # 0.1 = 10% of requests tracked (0.0 to 1.0)

# Redis (optional, for BullMQ job queue)
# REDIS_URL="redis://localhost:6379"  # Local example (commented)
REDIS_URL="rediss://default:<YOUR_UPSTASH_PASSWORD>@<YOUR_UPSTASH_HOST>:6379"  # Upstash (recommended)

# Log level
LOG_LEVEL="info"

# Cron Jobs (Vercel scheduled tasks)
# Generate: openssl rand -hex 32
CRON_SECRET="your-dev-cron-secret-here"
# Set "true" only for self-hosted long-running process; "false" on Vercel
CRON_WORKER="false"

# Support auto-conversion overrides (optional)
SUPPORT_PUBLIC_BUSINESS_ID="" # Force public inquiries to this business id
SUPPORT_ASSIGN_USER_ID=""      # Assign created ticket to this staff user id

# Phase 2: AI Credits
AI_CREDITS_ENABLED="true"
AI_CREDITS_COST_BUSINESS_SCANNER="5"
AI_CREDITS_COST_SITE_BUILDER_AI="3"
AI_CREDITS_COST_MENU_SUGGESTIONS="2"

# Trial & Business Approval Settings
TRIAL_HASH_SECRET="your-trial-hash-secret-min-64-chars"
AUTO_APPROVE_THRESHOLD="30"
TRIAL_IP_RANGE_LIMIT="5"
CAPTCHA_ENABLED="false"
CAPTCHA_TEST_MODE="false"
CAPTCHA_TEST_TOKEN=""
DISPOSABLE_EMAIL_DOMAINS="tempmail.com,guerrillamail.com,10minutemail.com"

# Phase 2: Add-on Pricing (in RWF cents)
SITE_BUILDER_PRO_MONTHLY_PRICE="1200000"
DISCOVERY_FEATURED_MONTHLY_PRICE="800000"
DISCOVERY_PREMIUM_MONTHLY_PRICE="1500000"
AI_CREDITS_PACK_SMALL="1000000"
AI_CREDITS_PACK_MEDIUM="2500000"
AI_CREDITS_PACK_LARGE="4500000"
